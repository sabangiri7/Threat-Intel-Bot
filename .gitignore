# ==============================================================================
# Automated Threat Intelligence Bot - Security & Environment Exclusions
# ==============================================================================

# Environments
venv/
.venv/
env/
env.bak/
venv.bak/

# Credentials & Secrets (CRITICAL)
.env
.env.*
*.pem
*.key
output/auth_keys.json

# Caches & Python Artifacts
__pycache__/
*.py[cod]
*$py.class
.pytest_cache/
.coverage
htmlcov/
.tox/

# IDEs & Editor Artifacts
.cursor/
.vscode/
.idea/
*.swp
*.swo
.DS_Store

# Output & Generated Logs (Keep sample files, ignore massive dynamic logs)
output/
intel.log
logs/
*.log
!reports/VALIDATION.md

# Temporary Dumps & Archives (Do not upload to repo)
REPO_*.txt
*.zip
*.tar.gz
*.bak
*.tmp

# Streamlit Artifacts
.streamlit/